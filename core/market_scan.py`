        symbol = asset['symbol'].upper() if 'USDT' in asset['symbol'] else asset['symbol'].upper() + 'USDT'
        ticker = binance_data.get(symbol)
        if not ticker:
            continue
            
        prices = fetch_binance_klines(symbol)
        if not prices:
            continue
            
        rsi = calculate_wilders_rsi(prices)
        
        results.append({
            'symbol': symbol,
            'name': asset.get('name', symbol),
            'price': float(ticker['lastPrice']),
            'change': float(ticker['priceChangePercent']),
            'volume': float(ticker['quoteVolume']),
            'rsi': rsi
